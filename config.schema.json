{
  "pluginAlias": "knx-doorbell",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "ip": {
        "title": "KNX Router or Interface",
        "type": "string",
        "placeholder": "224.0.23.12",
        "description": "IP of the KNX Router."
      },
      "port": {
        "title": "KNX Port",
        "type": "integer",
        "minimum": 1,
        "maximum": 65535,
        "placeholder": "3671",
        "description": "KNX Port"
      },
      "devices": {
        "type": "array",
        "minItems": 1,
        "items": {
          "title": "Doorbells",
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "placeholder": "Display Name for Doorbell"
            },
            "listen_single_press": {
              "title": "Listen Single Press Address",
              "type": "string",
              "placeholder": "1/1/1",
              "pattern": "^(?:[0-9]|[12][0-9]|3[01])\\/(?:[0-7])\\/(?:[0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$"
            },
            "listen_double_press": {
              "title": "Listen Double Press Address",
              "type": "string",
              "placeholder": "1/1/1",
              "pattern": "^(?:[0-9]|[12][0-9]|3[01])\\/(?:[0-7])\\/(?:[0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$"
            },
            "listen_long_press": {
              "title": "Listen Long Press Address",
              "type": "string",
              "placeholder": "1/1/1",
              "pattern": "^(?:[0-9]|[12][0-9]|3[01])\\/(?:[0-7])\\/(?:[0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])$"
            }
          },
          "required": [
            "name",
            "listen_single_press"
          ]
        }
      }
    },
    "required": [
      "devices"
    ]
  },
  "layout": [
    {
      "key": "devices",
      "type": "array",
      "orderable": false,
      "buttonText": "Add Doorbell",
      "items": [
        "devices[].name",
        "devices[].listen_single_press",
        "devices[].listen_double_press",
        "devices[].listen_long_press"
      ]
    },
    {
      "type": "section",
      "title": "Global",
      "expandable": true,
      "expanded": false,
      "items": [
        "ip",
        "port"
      ]
    }
  ]
}
